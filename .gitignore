# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing & coverage
/coverage
htmlcov/
.tox/
.coverage
.coverage.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
nosetests.xml
coverage.xml
*.cover

# next.js build outputs
/.next/
/out/
/build
.turbo/

# env / secrets (critical - never commit to public repositories)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.pem
*.key
*.cert
secret.txt
secrets.json

# debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# vercel
.vercel

# typescript / compiler info
*.tsbuildinfo
next-env.d.ts

# IDEs and Editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Operating System files
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# Python files (rules / runner metadata)
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
ENV/
env/
pip-log.txt
pip-delete-this-directory.txt
poetry.lock
